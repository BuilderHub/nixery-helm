+// Copyright BuilderHub
+// SPDX-License-Identifier: Apache-2.0
+
+// Package metrics registers optional Prometheus collectors for Nixery.
+package metrics
+
+import (
+	"net/http"
+
+	"github.com/google/nixery/config"
+	"github.com/prometheus/client_golang/prometheus"
+	"github.com/prometheus/client_golang/prometheus/promhttp"
+)
+
+var (
+	active bool
+
+	buildsAttempted prometheus.Counter
+	buildsSucceeded prometheus.Counter
+	buildsFailed    prometheus.Counter
+	buildDuration   prometheus.Histogram
+	manifestsServed prometheus.Counter
+	manifestBytes   prometheus.Counter
+	blobBytes       prometheus.Counter
+)
+
+// Configure registers Prometheus collectors when cfg.MetricsEnabled is true and
+// returns a handler for that registry. If metrics are disabled, it returns nil.
+func Configure(cfg config.Config) http.Handler {
+	if !cfg.MetricsEnabled {
+		active = false
+		return nil
+	}
+
+	reg := prometheus.NewRegistry()
+
+	buildsAttempted = prometheus.NewCounter(prometheus.CounterOpts{
+		Name: "nixery_builds_attempted_total",
+		Help: "Manifest build attempts that missed the manifest cache (excludes cache hits).",
+	})
+	buildsSucceeded = prometheus.NewCounter(prometheus.CounterOpts{
+		Name: "nixery_builds_succeeded_total",
+		Help: "Manifest builds that completed without handler or Nix-level errors (non-cache only).",
+	})
+	buildsFailed = prometheus.NewCounter(prometheus.CounterOpts{
+		Name: "nixery_builds_failed_total",
+		Help: "Manifest builds that failed with an error or Nix-reported image error (non-cache only).",
+	})
+	buildDuration = prometheus.NewHistogram(prometheus.HistogramOpts{
+		Name:    "nixery_build_duration_seconds",
+		Help:    "Wall time spent in BuildImage for non-cache attempts.",
+		Buckets: []float64{1, 5, 15, 30, 60, 120, 300, 600, 1800, 3600, 7200},
+	})
+	manifestsServed = prometheus.NewCounter(prometheus.CounterOpts{
+		Name: "nixery_manifests_served_total",
+		Help: "HTTP 200 responses with a manifest body (includes cache hits).",
+	})
+	manifestBytes = prometheus.NewCounter(prometheus.CounterOpts{
+		Name: "nixery_manifest_response_bytes_total",
+		Help: "Bytes written to clients in successful manifest responses.",
+	})
+	blobBytes = prometheus.NewCounter(prometheus.CounterOpts{
+		Name: "nixery_blob_response_bytes_total",
+		Help: "Bytes written to clients in successful blob responses.",
+	})
+
+	reg.MustRegister(
+		buildsAttempted,
+		buildsSucceeded,
+		buildsFailed,
+		buildDuration,
+		manifestsServed,
+		manifestBytes,
+		blobBytes,
+	)
+
+	active = true
+
+	return promhttp.HandlerFor(reg, promhttp.HandlerOpts{})
+}
+
+func IncBuildAttempted() {
+	if !active {
+		return
+	}
+	buildsAttempted.Inc()
+}
+
+func ObserveBuildDuration(seconds float64) {
+	if !active {
+		return
+	}
+	buildDuration.Observe(seconds)
+}
+
+func IncBuildSucceeded() {
+	if !active {
+		return
+	}
+	buildsSucceeded.Inc()
+}
+
+func IncBuildFailed() {
+	if !active {
+		return
+	}
+	buildsFailed.Inc()
+}
+
+func IncManifestsServed() {
+	if !active {
+		return
+	}
+	manifestsServed.Inc()
+}
+
+func AddManifestBytes(n int64) {
+	if !active || n <= 0 {
+		return
+	}
+	manifestBytes.Add(float64(n))
+}
+
+func AddBlobBytes(n int64) {
+	if !active || n <= 0 {
+		return
+	}
+	blobBytes.Add(float64(n))
+}
