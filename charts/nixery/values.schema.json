{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string" }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" }
        }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "podAnnotations": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "runtimeClassName": { "type": "string" },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "annotations": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "host": { "type": "string" },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": { "type": "string" },
                    "pathType": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "tls": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "resources": { "type": "object" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": "integer", "minimum": 0 }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": {
          "type": ["integer", "string"]
        },
        "targetMemoryUtilizationPercentage": {
          "type": ["integer", "string"]
        }
      }
    },
    "nixery": {
      "type": "object",
      "properties": {
        "channel": { "type": "string" },
        "pkgsRepo": { "type": "string" },
        "pkgsPath": { "type": "string" },
        "timeout": { "type": "string" },
        "popularityUrl": { "type": "string" },
        "nixConfig": { "type": "string" },
        "securityContext": {
          "type": ["object", "null"]
        },
        "extraEnv": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["s3", "gcs", "filesystem"]
        },
        "s3": {
          "type": "object",
          "properties": {
            "bucket": { "type": "string" },
            "endpoint": { "type": "string" },
            "region": { "type": "string" },
            "existingSecret": { "type": "string" },
            "accessKeyKey": { "type": "string" },
            "secretKeyKey": { "type": "string" },
            "createSecret": { "type": "boolean" },
            "accessKey": { "type": "string" },
            "secretKey": { "type": "string" }
          }
        },
        "gcs": {
          "type": "object",
          "properties": {
            "bucket": { "type": "string" },
            "existingSecret": { "type": "string" },
            "credentialsKey": { "type": "string" },
            "mountPath": { "type": "string" }
          }
        },
        "filesystem": {
          "type": "object",
          "properties": {
            "storagePath": { "type": "string" },
            "emptyDir": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "sizeLimit": { "type": "string" }
              }
            },
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "existingClaim": { "type": "string" },
                "storageClass": { "type": "string" },
                "size": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "tmp": {
      "type": "object",
      "properties": {
        "emptyDir": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "medium": { "type": "string" },
            "sizeLimit": { "type": "string" }
          }
        }
      }
    },
    "extraVolumes": { "type": "array" },
    "extraVolumeMounts": { "type": "array" },
    "extraEnvFrom": { "type": "array" }
  }
}
