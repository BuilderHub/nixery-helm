{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 1
    },
    "runtimeClassName": {
      "type": "string"
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" }
      }
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string" }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "backend": {
          "type": "string",
          "enum": ["s3", "gcs", "filesystem"]
        }
      }
    },
    "nixery": {
      "type": "object",
      "properties": {
        "channel": { "type": "string" },
        "pkgsRepo": { "type": "string" },
        "pkgsPath": { "type": "string" },
        "timeout": { "type": "string" },
        "popularityUrl": { "type": "string" },
        "nixConfig": { "type": "string" }
      }
    },
    "autoscaling": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
